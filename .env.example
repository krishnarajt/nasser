# Telegram
TELEGRAM_BOT_TOKEN=123456:replace_me
TELEGRAM_ALLOWED_USER_IDS=123456789
# Optional. Leave empty for any chat used by the allowed user.
TELEGRAM_ALLOWED_CHAT_IDS=

# Display name shown in Telegram.
NASSER_NAME="Home NAS"

# Policy/thresholds/action allowlists.
NASSER_POLICY_PATH=/etc/nasser/policy.yaml

# Runtime settings changed from the Telegram Settings menu are persisted here.
# The directory must be writable by the nasser user (see README).
NASSER_STATE_PATH=/var/lib/nasser/settings.json

# Alerts. If NASSER_ALERT_CHAT_IDS is empty, alerts use TELEGRAM_ALLOWED_CHAT_IDS.
# If both are empty, alerts begin after an allowed user opens the bot at least once.
NASSER_ALERTS_ENABLED=true
NASSER_ALERT_CHAT_IDS=
NASSER_ALERT_INTERVAL_SECONDS=300
NASSER_ALERT_REPEAT_SECONDS=3600

# k3s. Copy /etc/rancher/k3s/k3s.yaml to /etc/nasser/k3s.yaml and point here.
KUBECONFIG=/etc/nasser/k3s.yaml
NASSER_K3S_SERVICE=k3s

# Docker. Usually leave DOCKER_HOST empty so the Docker SDK uses /var/run/docker.sock.
DOCKER_HOST=
NASSER_DOCKER_SERVICE=docker

# Comma-separated block devices for SMART details.
# Prefer stable paths from: ls -l /dev/disk/by-id/
# Easier: leave this empty and pick disks from Telegram:
#   /menu -> Settings -> SMART disks (auto-discovered via lsblk)
NASSER_DISK_DEVICES=

# Journal units exposed in the Logs menu.
NASSER_LOG_UNITS=k3s,docker,containerd,ssh

# Services that can be restarted from Telegram.
NASSER_RESTARTABLE_SERVICES=k3s,docker

# Command behavior.
NASSER_USE_SUDO=true
NASSER_LOG_TAIL_LINES=200
NASSER_COMMAND_TIMEOUT_SECONDS=20
NASSER_SUDO_BIN=/usr/bin/sudo
NASSER_SYSTEMCTL_BIN=/bin/systemctl
NASSER_JOURNALCTL_BIN=/bin/journalctl
NASSER_SMARTCTL_BIN=/usr/sbin/smartctl
NASSER_LSBLK_BIN=/usr/bin/lsblk
NASSER_DOCKER_BIN=/usr/bin/docker
NASSER_PING_BIN=/bin/ping
NASSER_UPSC_BIN=/usr/bin/upsc
NASSER_VNSTAT_BIN=/usr/bin/vnstat
NASSER_SS_BIN=/usr/bin/ss
NASSER_APT_BIN=/usr/bin/apt-get
